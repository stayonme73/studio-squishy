# The Studio — environment variables (repo: studio-squishy)
# Copy to .env.local for local development.

# Public site URL (optional for MVP; used in metadata and absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev sidebar status jumpers (Studio Board pages) — off by default
# Owner QA nav is always available in local development.
# Payment page Test Payment sandbox: always on in local dev; on Vercel set below on Preview only.
# NEXT_PUBLIC_DEV_TOOLS=1
# NEXT_PUBLIC_PAYMENT_SANDBOX=1

# --- Post-MVP: Supabase (do not configure during MVP setup) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
